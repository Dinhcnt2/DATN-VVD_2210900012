@model IEnumerable<VVD_2210900012_DATN.Models.GioHang>

@{
    ViewData["Title"] = "Index";
}

<style>
    body {
        background: #f5f6fa;
    }

    h1 {
        font-size: 26px;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .card-box {
        background: #fff;
        padding: 20px;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }

    .btn-create {
        background: linear-gradient(45deg, #ff6a00, #ff914d);
        color: white;
        padding: 8px 15px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
    }

    .table-custom thead {
        background: linear-gradient(45deg, #007bff, #00c6ff);
        color: white;
    }

    .table-custom th,
    .table-custom td {
        text-align: center;
        vertical-align: middle;
    }

    .table-custom tbody tr:hover {
        background: #f1f1f1;
    }

    .price {
        color: red;
        font-weight: bold;
    }

    .status {
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
    }

    .active {
        background: #28a745;
        color: white;
    }

    .inactive {
        background: #dc3545;
        color: white;
    }

    .btn-action {
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 13px;
        text-decoration: none;
        margin: 2px;
        display: inline-block;
    }

    .edit {
        background: #ffc107;
        color: black;
    }

    .detail {
        background: #17a2b8;
        color: white;
    }

    .delete {
        background: #dc3545;
        color: white;
    }
</style>

<h1>🛒 Danh sách Giỏ Hàng</h1>

<p>
    <a asp-action="Create" class="btn-create">➕ Thêm mới</a>
</p>

<div class="card-box">

    <table class="table table-hover table-custom">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.SessionId)</th>
                <th>@Html.DisplayNameFor(model => model.TongTien)</th>
                <th>@Html.DisplayNameFor(model => model.TrangThai)</th>
                <th>@Html.DisplayNameFor(model => model.GhiChu)</th>
                <th>@Html.DisplayNameFor(model => model.NgayTao)</th>
                <th>@Html.DisplayNameFor(model => model.NgayCapNhat)</th>
                <th>Người dùng</th>
                <th>Hành động</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.SessionId</td>

                    <td class="price">
                        @item.TongTien?.ToString("N0") đ
                    </td>

                    <td>
                        @if (item.TrangThai == "Active")
                        {
                            <span class="status active">Hoạt động</span>
                        }
                        else
                        {
                            <span class="status inactive">Không hoạt động</span>
                        }
                    </td>

                    <td>@item.GhiChu</td>

                    <td>
                        @item.NgayTao?.ToString("dd/MM/yyyy HH:mm")
                    </td>

                    <td>
                        @item.NgayCapNhat?.ToString("dd/MM/yyyy HH:mm")
                    </td>

                    <td>
                        User #@item.MaNguoiDungNavigation?.MaNguoiDung
                    </td>

                    <td>
                        <a asp-action="Edit"
                           asp-route-id="@item.MaGioHang"
                           class="btn-action edit">
                            ✏️ Sửa
                        </a>

                        <a asp-action="Details"
                           asp-route-id="@item.MaGioHang"
                           class="btn-action detail">
                            👁 Xem
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.MaGioHang"
                           class="btn-action delete"
                           onclick="return confirm('Xoá giỏ hàng này?')">
                            🗑 Xoá
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>