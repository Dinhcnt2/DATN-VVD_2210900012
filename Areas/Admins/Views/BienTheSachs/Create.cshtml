@model VVD_2210900012_DATN.Models.BienTheSach

<h2>Thêm biến thể</h2>

<form asp-action="Create">

    <div class="form-group">
        <label>Sách</label>
        <select asp-for="SanPhamId" class="form-control"
                asp-items="ViewBag.SanPhamId">
            <option value="">-- Chọn sách --</option>
        </select>
    </div>

    <div class="form-group">
        <label>Loại bìa</label>
        <select asp-for="LoaiBiaId" class="form-control"
                asp-items="ViewBag.LoaiBiaId">
            <option value="">-- Chọn loại bìa --</option>
        </select>
    </div>

    <div class="form-group">
        <label>Ngôn ngữ</label>
        <select asp-for="NgonNguId" class="form-control"
                asp-items="ViewBag.NgonNguId">
            <option value="">-- Chọn ngôn ngữ --</option>
        </select>
    </div>

    <div class="form-group">
        <label>Số lượng</label>
        <input asp-for="SoLuongTon" class="form-control" />
    </div>

    <button class="btn btn-success">Thêm</button>
</form>
