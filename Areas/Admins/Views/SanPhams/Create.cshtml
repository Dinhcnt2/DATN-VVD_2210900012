@model VVD_2210900012_DATN.Models.SanPham

@{
    ViewData["Title"] = "Thêm sách";
}

<div class="card">

    <div class="card-header bg-primary text-white">
        <h4>📚 Thêm sách mới</h4>
    </div>

    <div class="card-body">

        <form asp-action="Create" enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">

                <div class="col-md-6">

                    <div class="mb-3">
                        <label class="form-label">Danh mục</label>
                        <select asp-for="DanhMucId"
                                class="form-control"
                                asp-items="ViewBag.DanhMucId"></select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tên sách</label>
                        <input asp-for="TenSach" class="form-control" />
                        <span asp-validation-for="TenSach" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Slug</label>
                        <input asp-for="Slug" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tác giả</label>
                        <input asp-for="TacGia" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Nhà xuất bản</label>
                        <input asp-for="NhaXuatBan" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Năm xuất bản</label>
                        <input asp-for="NamXuatBan" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Số trang</label>
                        <input asp-for="SoTrang" class="form-control" />
                    </div>

                </div>


                <div class="col-md-6">

                    <div class="mb-3">
                        <label class="form-label">ISBN</label>
                        <input asp-for="Isbn" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Giá gốc</label>
                        <input asp-for="GiaGoc" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Giảm giá (%)</label>
                        <input asp-for="PhanTramGiam" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ảnh bìa sách</label>

                        <input type="file"
                               name="uploadImage"
                               class="form-control" />

                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả ngắn</label>
                        <textarea asp-for="MoTaNgan"
                                  class="form-control"
                                  rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả chi tiết</label>
                        <textarea asp-for="MoTaChiTiet"
                                  class="form-control"
                                  rows="4"></textarea>
                    </div>

                </div>

            </div>


            <div class="mt-3">

                <button type="submit" class="btn btn-success">
                    💾 Lưu sách
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    ← Quay lại
                </a>

            </div>

        </form>

    </div>

</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}