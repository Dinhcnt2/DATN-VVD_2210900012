@model List<VVD_2210900012_DATN.Controllers.GioHangItem>

@{
    ViewData["Title"] = "Giỏ hàng";
    var voucherId = Context.Session.GetInt32("VoucherId");
    var tongTien = Model.Sum(x => x.Gia * x.SoLuong);
}

<div class="container mt-4">

    <h2 class="mb-4">🛒 Giỏ hàng của bạn</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            Giỏ hàng trống!
        </div>
    }
    else
    {
        <table class="table table-bordered align-middle text-center">
            <thead class="table-warning">
                <tr>
                    <th>Sách</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Tổng</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TenSach</td>

                        <td class="text-danger fw-bold">
                            @item.Gia.ToString("N0") đ
                        </td>

                        <td style="width:200px;">
                            <input type="number"
                                   min="1"
                                   value="@item.SoLuong"
                                   class="form-control quantity"
                                   data-id="@item.Id" />
                        </td>

                        <td class="fw-bold text-success item-total">
                            @((item.Gia * item.SoLuong).ToString("N0")) đ
                        </td>

                        <td>
                            <a href="/GioHang/Xoa/@item.Id"
                               class="btn btn-danger btn-sm">
                                Xoá
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- 🔥 TỔNG -->
        <h4 class="text-end text-primary">
            Tổng tiền:
            <span id="cart-total">
                @tongTien.ToString("N0") đ
            </span>
        </h4>

        <hr />

        <!-- 🔥 VOUCHER -->
        <h5>🎟 Voucher</h5>

        <!-- nhập code -->
        <div class="mb-3 d-flex">
            <input type="text"
                   id="voucherCode"
                   class="form-control"
                   placeholder="Nhập mã voucher..." />

            <button class="btn btn-primary ms-2"
                    onclick="applyVoucher()">
                Áp dụng
            </button>
        </div>

        <!-- chọn voucher -->
        <button class="btn btn-warning mb-3"
                onclick="openVoucherModal()">
            🎟 Chọn Voucher
        </button>

        <!-- hiển thị -->
        <div id="voucher-selected" class="text-success mb-3">
            @if (voucherId != null)
            {
                <text>✅ Đã áp dụng voucher</text>
            }
        </div>

        <!-- FORM -->
        <h4 class="mb-3">📦 Thông tin nhận hàng</h4>

        <form method="post" action="/GioHang/DatHang">

            <input name="ten"
                   class="form-control mb-2"
                   placeholder="👤 Tên người nhận"
                   required />

            <input name="sdt"
                   class="form-control mb-2"
                   placeholder="📞 SĐT"
                   required />

            <input name="diachi"
                   class="form-control mb-3"
                   placeholder="🏠 Địa chỉ"
                   required />

            <button class="btn btn-success w-100 btn-lg">
                ✅ Đặt hàng ngay
            </button>
        </form>
    }
</div>

<!-- 🔥 MODAL -->
<div class="modal fade" id="voucherModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5>🎟 Chọn Voucher</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="voucherList">
                Loading...
            </div>

        </div>
    </div>
</div>

<!-- 🔥 SCRIPT -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
        // ===== UPDATE REALTIME =====
        $(".quantity").on("change", function () {

            var input = $(this);
            var id = input.data("id");
            var soluong = input.val();
            var row = input.closest("tr");

            $.post("/GioHang/UpdateAjax",
                { id: id, soluong: soluong },
                function (res) {

                    row.find(".item-total").text(
                        res.itemTotal.toLocaleString() + " đ"
                    );

                    $("#cart-total").text(
                        res.cartTotal.toLocaleString() + " đ"
                    );
                });
        });

        // ===== NHẬP VOUCHER =====
        function applyVoucher() {

            var code = $("#voucherCode").val();

            if (!code) {
                alert("Nhập mã voucher!");
                return;
            }

            $.post("/GioHang/NhapVoucher",
                { code: code },
                function (res) {

                    if (res.success) {
                        alert("Áp dụng thành công!");
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                });
        }

        // ===== MỞ MODAL =====
        function openVoucherModal() {
            var modal = new bootstrap.Modal(document.getElementById('voucherModal'));
            modal.show();

            $("#voucherList").load("/GioHang/GetVoucherList");
        }

        // ===== CHỌN VOUCHER (FIX LỖI) =====
        function chonVoucher(id) {
            $.post("/GioHang/ChonVoucher",
    { id: id },
                function () {
                    location.reload();
                });
        }
</script>
