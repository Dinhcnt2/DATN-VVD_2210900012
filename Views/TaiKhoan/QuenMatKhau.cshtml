@{
    ViewData["Title"] = "Quên mật khẩu";
}

<style>
    .box {
        max-width: 400px;
        margin: 80px auto;
        padding: 30px;
        border-radius: 15px;
        background: white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .title {
        text-align: center;
        font-weight: bold;
        margin-bottom: 20px;
    }
</style>

<div class="box">
    <h3 class="title">🔑 Quên mật khẩu</h3>

    <form method="post">
        <input name="TenDangNhap"
               class="form-control mb-3"
               placeholder="Nhập tên đăng nhập"
               required />

        <button class="btn btn-primary w-100">
            Gửi mã xác nhận
        </button>
    </form>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger mt-3">
            @ViewBag.Error
        </div>
    }
</div>