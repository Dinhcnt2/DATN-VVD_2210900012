@model VVD_2210900012_DATN.Models.NguoiDung

@{
    ViewData["Title"] = "Đăng ký";
}

<style>
    body {
        background: linear-gradient(135deg, #ffe6ec, #fff);
    }

    .register-box {
        background: white;
        padding: 35px;
        border-radius: 20px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
        animation: fadeIn 0.6s ease;
    }

    

    h3 {
        font-weight: bold;
        color: #ff6b81;
    }

    .form-control {
        border-radius: 12px;
        border: 1px solid #ddd;
        padding: 10px 12px;
        transition: 0.3s;
    }

    .form-control:focus {
        border-color: #ff6b81;
        box-shadow: 0 0 8px rgba(255,107,129,0.4);
    }

    .btn-primary {
        background: linear-gradient(45deg, #ff6b81, #ff9472);
        border: none;
        border-radius: 12px;
        padding: 10px;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-primary:hover {
        transform: scale(1.05);
        opacity: 0.9;
    }

    .alert {
        border-radius: 10px;
    }

    .link-login {
        color: #ff6b81;
        font-weight: 500;
        text-decoration: none;
    }

    .link-login:hover {
        text-decoration: underline;
    }
</style>

<div class="row justify-content-center">
    <div class="col-md-5">

        <div class="register-box">

            <h3 class="text-center mb-4">Đăng ký tài khoản</h3>

            <form method="post">

                <input asp-for="TenDangNhap" class="form-control mb-3" placeholder="Tên đăng nhập" required />

                <input asp-for="MatKhau" type="password" class="form-control mb-3" placeholder="Mật khẩu" required />

                <input asp-for="HoTen" class="form-control mb-3" placeholder="Họ tên" />

                <input asp-for="Email" class="form-control mb-3" placeholder="Email" />

                <input asp-for="Sdt" class="form-control mb-4" placeholder="Số điện thoại" />

                <button class="btn btn-primary w-100">
                    Đăng ký
                </button>

            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3">
                    @ViewBag.Error
                </div>
            }

            <div class="text-center mt-3">
                <a href="/TaiKhoan/DangNhap" class="link-login">
                    Đã có tài khoản? Đăng nhập
                </a>
            </div>

        </div>

    </div>
</div>
