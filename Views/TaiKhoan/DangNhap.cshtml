@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    body {
        background: linear-gradient(135deg, #ffe6ec, #fff);
    }

    .login-box {
        background: white;
        padding: 35px;
        border-radius: 20px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
        animation: fadeIn 0.6s ease;
    }

    

    h3 {
        font-weight: bold;
        color: #ff6b81;
    }

    label {
        font-weight: 500;
        margin-bottom: 5px;
    }

    .form-control {
        border-radius: 12px;
        border: 1px solid #ddd;
        padding: 10px 12px;
        transition: 0.3s;
    }

        .form-control:focus {
            border-color: #ff6b81;
            box-shadow: 0 0 8px rgba(255,107,129,0.4);
        }

    .btn-primary {
        background: linear-gradient(45deg, #ff6b81, #ff9472);
        border: none;
        border-radius: 12px;
        padding: 10px;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-primary:hover {
            transform: scale(1.05);
            opacity: 0.9;
        }

    .alert {
        border-radius: 10px;
    }

    .extra-links {
        margin-top: 10px;
        display: flex;
        justify-content: space-between;
        font-size: 14px;
    }

        .extra-links a {
            color: #ff6b81;
            text-decoration: none;
            font-weight: 500;
        }

            .extra-links a:hover {
                text-decoration: underline;
            }
</style>

<div class="row justify-content-center">
    <div class="col-md-4">

        <div class="login-box">

            <h3 class="text-center mb-4">Đăng nhập</h3>

            <form method="post">

                <div class="mb-3">
                    <label>Tên đăng nhập</label>
                    <input name="TenDangNhap" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label>Mật khẩu</label>
                    <input name="MatKhau" type="password" class="form-control" required />
                </div>

                <button class="btn btn-primary w-100">
                    Đăng nhập
                </button>

            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3">
                    @ViewBag.Error
                </div>
            }

            <!-- LINK PHỤ -->
            <div class="extra-links">
                <a href="/TaiKhoan/QuenMatKhau">Quên mật khẩu?</a>
                <a href="/TaiKhoan/DangKy">Đăng ký</a>
            </div>

        </div>

    </div>
</div>
