@model List<VVD_2210900012_DATN.Models.DanhGia>

<h4>⭐ Đánh giá sản phẩm</h4>

@if (!Model.Any())
{
    <p>Chưa có đánh giá</p>
}
else
{
    foreach (var item in Model)
    {
        <div class="border p-2 mb-2">

            <b>@item.MaNguoiDungNavigation?.TenDangNhap</b>

            <div>
                @for (int i = 1; i <= 5; i++)
                {
                    if (i <= item.SoSao)
                    {
                        <span style="color:orange;">★</span>
                    }
                    else
                    {
                        <span>☆</span>
                    }
                }
            </div>

            <p>@item.NoiDung</p>

            <small>@item.NgayDanhGia?.ToString("dd/MM/yyyy HH:mm")</small>

        </div>
    }
}