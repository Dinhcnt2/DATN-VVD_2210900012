@{
    ViewData["Title"] = "Liên hệ";
}

<style>
    .contact-box {
        max-width: 600px;
        margin: auto;
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }

        .contact-box h3 {
            font-weight: bold;
            margin-bottom: 15px;
        }
</style>

<div class="container mt-4">

    <div class="contact-box">

        <h3>📩 Liên hệ với chúng tôi</h3>

        @if (TempData["msg"] != null)
        {
            <div class="alert alert-success">
                @TempData["msg"]
            </div>
        }

        <form method="post" action="/LienHe/Gui">

            <input name="hoTen" class="form-control mb-2" placeholder="👤 Họ tên" required />

            <input name="email" class="form-control mb-2" placeholder="📧 Email" required />

            <input name="tieuDe" class="form-control mb-2" placeholder="📌 Tiêu đề" />

            <textarea name="noiDung"
                      class="form-control mb-3"
                      rows="4"
                      placeholder="✍ Nội dung"
                      required></textarea>

            <button class="btn btn-primary w-100">
                🚀 Gửi liên hệ
            </button>

        </form>

        <hr />

        <!-- 🔥 INFO (CHO THẦY HỎI) -->
        <div class="mt-3">
            <p><b>📞 Hotline:</b> 0123 456 789</p>
            <p><b>📧 Email:</b> admin@bookstore.com</p>
            <p><b>📍 Địa chỉ:</b> Hà Nội</p>
        </div>

    </div>

</div>