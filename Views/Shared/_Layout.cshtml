<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        body {
            background: #f5f5f5;
        }

        .logo {
            font-weight: bold;
            font-size: 22px;
            color: #ff6a00 !important;
        }

        .navbar-nav .nav-link {
            font-weight: 500;
            transition: 0.2s;
        }

            .navbar-nav .nav-link:hover {
                color: #ff6a00 !important;
                transform: translateY(-1px);
            }

        .nav-active {
            color: #ff6a00 !important;
            font-weight: bold;
            border-bottom: 2px solid #ff6a00;
        }

        .search-wrapper {
            position: relative;
            width: 300px;
        }

        #goiY {
            position: absolute;
            top: 40px;
            width: 100%;
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            z-index: 999;
        }

            #goiY a {
                display: flex;
                align-items: center;
                padding: 8px;
                gap: 10px;
                text-decoration: none;
                color: black;
            }

                #goiY a:hover {
                    background: #ffe4ec;
                }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
            <div class="container">

                <a class="navbar-brand logo" asp-controller="Home" asp-action="Index">
                    📚 BookStore
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menu">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"nav-active":"")"
                               asp-controller="Home" asp-action="Index">
                                Trang chủ
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Sach"?"nav-active":"")"
                               asp-controller="Sach" asp-action="Index">
                                Sách
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="BaiViet"?"nav-active":"")"
                               asp-controller="BaiViet" asp-action="Index">
                                📰 Bài viết
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="GioHang"?"nav-active":"")"
                               asp-controller="GioHang" asp-action="Index">
                                🛒 Giỏ hàng
                            </a>
                        </li>

                        <!-- 🔥 THÊM LIÊN HỆ (NEW) -->
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="LienHe"?"nav-active":"")"
                               asp-controller="LienHe" asp-action="Index">
                                📩 Liên hệ
                            </a>
                        </li>

                    </ul>

                    <!-- SEARCH -->
                    <div class="search-wrapper me-3">
                        <input id="searchBox" class="form-control" placeholder="🔍 Tìm sách..." autocomplete="off" />
                        <div id="goiY"></div>
                    </div>

                    <!-- USER -->
                    <ul class="navbar-nav">
                        @if (Context.Session.GetString("TenNguoiDung") == null)
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary me-2" asp-controller="TaiKhoan" asp-action="DangNhap">
                                    Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary" asp-controller="TaiKhoan" asp-action="DangKy">
                                    Đăng ký
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item mt-2 me-2">
                                Xin chào:
                                <b>@Context.Session.GetString("TenNguoiDung")</b>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-danger" asp-controller="TaiKhoan" asp-action="DangXuat">
                                    Đăng xuất
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script>
            $("#searchBox").keyup(function () {

                var keyword = $(this).val();

                if (keyword.length === 0) {
                    $("#goiY").html("");
                    return;
                }

                $.get("/Sach/TimKiemAjax", { keyword: keyword }, function (data) {

                    var html = "";

                    data.forEach(function (item) {
                        html += `
                            <a href="/Sach/ChiTiet/${item.id}">
        <img src="/images/${item.anh}" width="40"/>
                                ${item.ten} - ${item.gia.toLocaleString()} đ
                            </a>
                        `;
                    });

                    $("#goiY").html(html);
                });
            });
    </script>

</body>
</html>
