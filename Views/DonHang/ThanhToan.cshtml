@{
    ViewData["Title"] = "Thanh toán";
}

<style>
    body {
        background: linear-gradient(135deg, #f6f9fc, #e9f1ff);
    }

    .box {
        width: 420px;
        margin: 60px auto;
        text-align: center;
        background: white;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .title {
        font-size: 24px;
        font-weight: bold;
        color: #ff6a00;
        margin-bottom: 10px;
    }

    .info {
        margin: 10px 0;
        font-size: 16px;
    }

    .money {
        font-size: 22px;
        color: red;
        font-weight: bold;
    }

    img {
        width: 260px;
        margin: 20px 0;
        padding: 10px;
        border-radius: 15px;
        border: 1px solid #ddd;
        background: #fff;
    }

    .note {
        color: #dc3545;
        font-weight: bold;
        margin-top: 10px;
    }

    .btn-home {
        display: inline-block;
        margin-top: 15px;
        padding: 10px 20px;
        background: linear-gradient(45deg, #ff6a00, #ff914d);
        color: white;
        border-radius: 25px;
        text-decoration: none;
    }

        .btn-home:hover {
            opacity: 0.9;
        }
</style>

<div class="box">

    <div class="title">💳 Thanh toán QR</div>

    <div class="info">
        Mã đơn: <b>@ViewBag.MaDon</b>
    </div>

    <div class="info">
        Số tiền:
        <div class="money">
            @(((decimal)ViewBag.TongTien).ToString("N0")) đ
        </div>
    </div>

    <img src="@ViewBag.QR" />

    <div class="note">
        Nội dung CK: @ViewBag.MaDon
    </div>

    <a href="/" class="btn-home">🏠 Về trang chủ</a>

</div>
