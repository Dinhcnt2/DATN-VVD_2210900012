@model VVD_2210900012_DATN.Models.BaiViet

<div class="container mt-4">

    <h2>@Model.TieuDe</h2>

    <p class="text-muted">
        @Model.CreatedAt?.ToString("dd/MM/yyyy")
    </p>

    @if (!string.IsNullOrEmpty(Model.HinhAnh))
    {
        <img src="@Model.HinhAnh" class="img-fluid mb-3" />
    }

    <hr />

    <div style="line-height:1.8">
        @Model.NoiDung
    </div>

    <a href="/BaiViet" class="btn btn-secondary mt-3">
        ⬅ Quay lại
    </a>

</div>